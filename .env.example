# ============================================================
# 队列 Redis（任务队列 Broker，如使用 SSH 隧道则填 127.0.0.1:本地映射端口）
# ============================================================
QUEUE_REDIS_HOST=127.0.0.1
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=
QUEUE_REDIS_DB=0

# ============================================================
# 业务 Redis（抓取器自已用的缓存 / 去重，如使用 SSH 隧道则填 127.0.0.1:本地映射端口）
# ============================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# ============================================================
# MySQL 配置（如使用 SSH 隧道则填 127.0.0.1:本地映射端口）
# ============================================================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=xigscraper
TABLE_PREFIX=la_

# ============================================================
# 任务队列参数
# ============================================================
TASK_VISIBILITY_TIMEOUT=600
MAX_RETRIES=3
RETRY_DELAY_BASE=60

# ============================================================
# Worker 参数
# ============================================================
WORKER_HEARTBEAT_INTERVAL=30
WORKER_HEARTBEAT_TIMEOUT=90
MAX_TASKS_PER_WORKER=0

# ============================================================
# Producer 参数
# ============================================================
PRODUCER_POLL_INTERVAL=30

# ============================================================
# Instagram 爬虫配置
# ============================================================
IG_CHROME_PATH=/path/to/chrome
IG_CHROMEDRIVER_PATH=/path/to/chromedriver
IG_USERNAME=
IG_PASSWORD=

CHROME_HEADLESS=1


# ============================================================
# X (Twitter) 爬虫配置
# ============================================================
X_AUTH_TOKEN=


# ============================================================
# Storage 文件存储
# ============================================================
#通过 .env 配置:
#STORAGE_BACKEND=aliyun|qiniu|tencent|local
STORAGE_BACKEND=aliyun
STORAGE_BASE_URL=https://your-cdn.com    # 对外访问域名
STORAGE_LOCAL_DIR=/home/www/uploads      # local 模式必填

#阿里云:
ALIYUN_ACCESS_KEY_ID=xxx
ALIYUN_ACCESS_KEY_SECRET=xxx
ALIYUN_OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
ALIYUN_OSS_BUCKET=your-bucket
